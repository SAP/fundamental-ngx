{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc/ui5-webcomponents-base",
        "target": "es2023",
        "declaration": true,
        "declarationMap": true,
        "types": [],
        "lib": [
            "dom",
            "es2023"
        ],
        "useDefineForClassFields": false,
        "moduleResolution": "bundler",
        "composite": true,
        "paths": {
            "@fundamental-ngx/i18n": [
                "dist/libs/i18n"
            ],
            "@fundamental-ngx/core/theming": [
                "dist/libs/core/theming"
            ]
        }
    },
    "angularCompilerOptions": {
        "skipTemplateCodegen": true,
        // TODO(#14334): suppress Angular 22 optionalChainNotNullable and nullishCoalescingNotNullable diagnostics
        "extendedDiagnostics": {
            "checks": {
                "nullishCoalescingNotNullable": "suppress",
                "optionalChainNotNullable": "suppress"
            }
        },
        "strictMetadataEmit": true,
        "enableResourceInlining": true
    },
    "files": [
        "./index.ts"
    ],
    "exclude": [
        "test.ts",
        "**/*.spec.ts"
    ],
    "include": [
        "**/*.ts"
    ]
}
