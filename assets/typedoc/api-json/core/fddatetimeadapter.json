    {
      "name": "toIso8601",
      "signature": "(fdDate: FdDate) => string",
      "description": "Gets the ISO 8601 date-time string for the given date.\n\nReturns a **local** (timezone-unaware) string in the format `YYYY-MM-DDTHH:mm:ss`.\nThis is intentionally **not** RFC 3339 compliant because no timezone designator is appended.\n\nThis method is used to generate date strings that are compatible with native HTML attributes\nsuch as the `min` or `max` attribute of an `<input>`.\n\nTo produce an RFC 3339 string, append a timezone designator to the result:\n```ts\nconst rfc3339Utc = adapter.toIso8601(date) + 'Z';          // UTC\nconst rfc3339Local = adapter.toIso8601(date) + '+05:30';    // with offset\n```",
      "deprecated": null,
      "sourceLine": 432,
      "since": null,
      "parameters": [
        {
          "name": "fdDate",
          "type": "FdDate",
          "description": "The date to get the ISO date string for.",
          "optional": false
        }
      ],
      "returnType": "string"
    },
