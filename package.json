{
    "name": "fundamental-ngx",
    "private": true,
    "license": "Apache-2.0",
    "main": "dist/libs/core/index.js",
    "description": "The official SAP Angular library for UI5 Web Components and Fiori design system. 1000+ components for Angular 21+.",
    "keywords": [
        "angular",
        "ui5",
        "ui5-webcomponents",
        "web-components",
        "sap",
        "fiori",
        "ngx",
        "design-system",
        "btp",
        "angular-components",
        "sap-fiori",
        "fundamental"
    ],
    "homepage": "https://sap.github.io/fundamental-ngx",
    "repository": {
        "type": "git",
        "url": "https://github.com/SAP/fundamental-ngx"
    },
    "engines": {
        "yarn": ">= 4.12.0",
        "node": ">= 22.22.3"
    },
    "packageManager": "yarn@4.12.0",
    "scripts": {
        "preinstall": "npx only-allow yarn",
        "build": "echo Building default app && nx compile",
        "build-docs-netlify": "yarn run build --configuration=production-unoptimized",
        "build:umbrella": "echo Building umbrella libraries && nx run-many --target=build --all",
        "build:umbrella:prod": "echo Building umbrella libraries PROD && yarn run build:umbrella -- --configuration=production",
        "build:prepare": "echo Building libraries and preparing for publishing && nx run-many --target=prepare --all --pack --configuration=production --skip-nx-cache",
        "test": "echo Running unit tests && nx run-many --target=test --all --parallel=10",
        "e2e": "playwright test",
        "e2e:update": "playwright test --update-snapshots",
        "e2e:report": "playwright show-report",
        "e2e:routes": "npx tsx apps/e2e-harness/scripts/generate-routes.ts && prettier --write apps/e2e-harness/src/app/app.routes.generated.ts apps/e2e-harness/e2e/config/e2e.routes.json",
        "cleanup": "find libs/ui5-webcomponents -mindepth 1 -type d -exec rm -r {} + && rm libs/ui5-webcomponents/index.ts && find libs/ui5-webcomponents-ai -mindepth 1 -type d -exec rm -r {} + && rm libs/ui5-webcomponents-ai/index.ts && find libs/ui5-webcomponents-fiori -mindepth 1 -type d -exec rm -r {} + && rm libs/ui5-webcomponents-fiori/index.ts && rm -rf libs/ui5-webcomponents-base/types && rm -rf dist",
        "generate:ui5": "echo Generating UI5 Webcomponents Wrappers && nx run-many --target=generate --projects=ui5-webcomponents,ui5-webcomponents-ai,ui5-webcomponents-fiori,ui5-webcomponents-base",
        "ng": "ng",
        "hotfix-release": "node scripts/release-hotfix.js",
        "start": "nx serve",
        "test:coveralls": "cat ./coverage/libs/core/lcov.info  | ./node_modules/coveralls/bin/coveralls.js || echo -e \"Coveralls failed.\"",
        "workspace-schematic": "./node_modules/.bin/nx workspace-schematic",
        "nx": "nx",
        "postinstall": "husky install",
        "pre-commit": "lint-staged",
        "format": "prettier . --write --list-different"
    },
    "publishConfig": {
        "registry": "https://repository.hybris.com/api/npm/npm-repository/"
    },
    "dependencies": {
        "@angular/cdk": "22.0.3",
        "@angular/common": "22.0.5",
        "@angular/compiler": "22.0.5",
        "@angular/core": "22.0.5",
        "@angular/forms": "22.0.5",
        "@angular/platform-browser": "22.0.5",
        "@angular/platform-browser-dynamic": "22.0.5",
        "@angular/router": "22.0.5",
        "@fundamental-styles/cx": "0.41.8",
        "@nx/angular": "23.0.1",
        "@sap-theming/theming-base-content": "11.36.4",
        "@stackblitz/sdk": "1.9.0",
        "@swc/helpers": "0.5.11",
        "@ui5/tooling-webc": "~0.3.1",
        "@ui5/webcomponents": "~2.24.0",
        "@ui5/webcomponents-ai": "~2.24.0",
        "@ui5/webcomponents-base": "~2.24.0",
        "@ui5/webcomponents-fiori": "~2.24.0",
        "@ui5/webcomponents-icons": "~2.24.0",
        "@ui5/webcomponents-icons-business-suite": "~2.24.0",
        "@ui5/webcomponents-icons-tnt": "~2.24.0",
        "@ui5/webcomponents-theming": "~2.24.0",
        "@ui5/webcomponents-tools": "~2.24.0",
        "compare-versions": "6.1.0",
        "core-js": "3.26.1",
        "dayjs": "1.11.11",
        "fast-equals": "^6.0.0",
        "focus-trap": "7.1.0",
        "focus-visible": "5.2.1",
        "fundamental-styles": "0.41.8",
        "fuse.js": "7.0.0",
        "highlight.js": "11.7.0",
        "intl": "1.2.5",
        "intl-messageformat": "10.5.2",
        "marked": "9.0.0",
        "moment": "2.29.4",
        "ngx-markdown": "19.0.0",
        "rxjs": "7.8.2",
        "tslib": "^2.3.0",
        "zone.js": "0.16.0"
    },
    "devDependencies": {
        "@actions/core": "1.10.1",
        "@angular-devkit/build-angular": "22.0.5",
        "@angular-devkit/core": "22.0.5",
        "@angular-devkit/schematics": "22.0.5",
        "@angular/cli": "22.0.5",
        "@angular/compiler-cli": "22.0.5",
        "@angular/language-service": "22.0.5",
        "@axe-core/playwright": "^4.11.2",
        "@commitlint/cli": "18.6.1",
        "@commitlint/config-conventional": "18.6.1",
        "@fundamental-styles/common-css": "0.41.8",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@nx/devkit": "22.4.1",
        "@nx/eslint": "22.4.1",
        "@nx/eslint-plugin": "22.4.1",
        "@nx/jest": "23.0.1",
        "@nx/js": "22.4.1",
        "@nx/playwright": "^22.7.0",
        "@nx/plugin": "22.4.1",
        "@nx/workspace": "22.4.1",
        "@playwright/test": "^1.59.1",
        "@schematics/angular": "22.0.5",
        "@swc-node/register": "1.9.2",
        "@swc/cli": "0.6.0",
        "@swc/core": "1.5.7",
        "@types/google.visualization": "0.0.71",
        "@types/jasmine": "5.1.3",
        "@types/jest": "30.0.0",
        "@types/marked": "5.0.2",
        "@types/node": "22.10.2",
        "@typescript-eslint/utils": "^8.29.0",
        "angular-eslint": "22.0.0",
        "autoprefixer": "^10.4.0",
        "axios": "1.6.0",
        "conventional-changelog": "4.0.0",
        "conventional-changelog-angular": "6.0.0",
        "conventional-changelog-cli": "3.0.0",
        "conventional-recommended-bump": "7.0.1",
        "coveralls": "3.1.1",
        "dependency-tree": "10.0.9",
        "eslint": "^9.28.0",
        "fast-glob": "3.3.1",
        "fs-extra": "^11.3.0",
        "husky": "8.0.2",
        "jasmine-core": "4.5.0",
        "jasmine-marbles": "0.9.2",
        "jasmine-spec-reporter": "7.0.0",
        "jest": "30.4.2",
        "jest-environment-jsdom": "30.4.1",
        "jest-environment-node": "30.4.1",
        "jest-extended": "7.0.0",
        "jest-preset-angular": "17.0.0",
        "jest-util": "30.4.1",
        "jsonc-eslint-parser": "^2.1.0",
        "lint-staged": "15.1.0",
        "ng-packagr": "22.0.1",
        "ngx-cva-test-suite": "2.0.1",
        "postcss-preset-env": "9.3.0",
        "postcss-url": "10.1.3",
        "prettier": "3.5.1",
        "prettier-plugin-organize-imports": "3.2.4",
        "semver": "7.6.3",
        "standard-version": "9.5.0",
        "through2": "4.0.2",
        "ts-jest": "29.4.11",
        "ts-node": "10.9.2",
        "tsconfig-paths": "4.1.0",
        "typedoc": "0.25.3",
        "typedoc-plugin-merge-modules": "5.1.0",
        "typescript": "6.0.3",
        "typescript-eslint": "^8.33.1",
        "wait-on": "6.0.1",
        "zod": "^4.3.6"
    },
    "resolutions": {
        "nx": "22.4.1",
        "parse5": "7.1.2",
        "tar": "7.5.8",
        "@ui5/project": "4.0.10",
        "sigstore@npm:^3.0.0": "npm:4.1.1",
        "sigstore@npm:^4.0.0": "npm:4.1.1"
    },
    "lint-staged": {
        "*.{js,ts,html,md,json,yml,css,scss}": [
            "prettier --write",
            "eslint --fix --flag v10_config_lookup_from_file"
        ]
    }
}
